{
  "name": "lavanda-pos",
  "version": "0.0.1",
  "private": true,
  "description": "Lavanda Pharmacy POS - Local-first pharmacy point of sale and stock management system",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev -w @lavanda/api",
    "dev:web": "npm run dev -w @lavanda/web",
    "build": "npm run build -w @lavanda/web && npm run build -w @lavanda/api",
    "build:web": "npm run build -w @lavanda/web",
    "build:api": "npm run build -w @lavanda/api",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "typecheck": "npm run typecheck -w @lavanda/api && npm run typecheck -w @lavanda/web",
    "db:generate": "npm run db:generate -w @lavanda/db",
    "db:migrate": "npm run db:migrate -w @lavanda/db",
    "db:studio": "npm run db:studio -w @lavanda/db"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "devDependencies": {
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
