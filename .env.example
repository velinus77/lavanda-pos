# Application
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# Database
DATABASE_PATH=./packages/data/lavanda.db

# Auth
ACCESS_TOKEN_SECRET=change-me-access-token-secret-min-32-chars
REFRESH_TOKEN_SECRET=change-me-refresh-token-secret-min-32-chars
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:3000
