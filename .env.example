# Application
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# Database
DATABASE_URL=file:./lavanda.db

# JWT
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRY=8h
JWT_REFRESH_SECRET=change-me-refresh-secret-use-a-long-random-string

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Security
BCRYPT_ROUNDS=12
